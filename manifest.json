{
  "manifest_version": 3,
  "name": "Recent Tab Switcher",
  "version": "2.0",
  "description": "Switch between recent tabs with a visual switcher popup (Alt+Q / Ctrl+Q)",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "switch-to-last-tab": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "MacCtrl+Q"
      },
      "description": "Open tab switcher"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}